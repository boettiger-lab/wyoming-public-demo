                    "default_style": {
                        "fill-color": ["match", ["get", "Mang_Name"],
                            "BLM",  "#D4A017",
                            "USFS", "#2D7D32",
                            "NPS",  "#4E7D5A",
                            "FWS",  "#1565C0",
                            "USBR", "#6A1B9A",
                            "DOD",  "#B71C1C",
                            "SLB",  "#E67E22",
                            "NGO",  "#AD1457",
                            "TRIB", "#E65100",
                            "#888888"
