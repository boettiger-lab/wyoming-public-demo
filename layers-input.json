                        "fill-opacity": 0.5,
                        "fill-outline-color": "rgba(0,0,0,0.15)"
                    },
                    "tooltip_fields": ["Unit_Nm", "Mang_Name", "GAP_Sts", "GIS_Acres"]
                }
            ]
        }
    ]
