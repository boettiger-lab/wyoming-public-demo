    "view": {
        "center": [-107.5, 43.0],
        "zoom": 7
    },
    "_llm_note": "Uncomment the llm block below for GitHub Pages / static hosting (no server secrets). For Kubernetes, delete it — the k8s/ manifests inject config.json with API keys at deploy time.",
    "llm": {
        "user_provided": true,
        "default_endpoint": "https://openrouter.ai/api/v1",
        "models": [
            { "value": "qwen/qwen3-235b-a22b", "label": "Qwen3 235B" },
            { "value": "moonshotai/kimi-k2", "label": "Kimi K2" },
            { "value": "minimax/minimax-m1", "label": "MiniMax M1" },
            { "value": "anthropic/claude-sonnet-4", "label": "Claude Sonnet" },
            { "value": "google/gemini-2.5-flash", "label": "Gemini Flash" }
        ]
    },
    "collections": [
        {
            "collection_id": "wyoming-wildlife-lands",
            "assets": [
                {
                    "id": "nlcd-2024-cog",
                    "display_name": "NLCD 2024 Land Cover",
                    "group": "Land Cover",
                    "legend_type": "categorical",
                    "paint": {"raster-opacity": 0.5}
                },
                {
                    "id": "sagebrush-cog",
                    "display_name": "Sagebrush Conservation Design",
                    "group": "Land Cover",
                    "colormap": "rdylgn",
                    "rescale": "1,3",
                    "legend_label": "class (1=Core, 3=Other)"
                },
                {
                    "id": "rap-arte-cog",
                    "display_name": "Sagebrush Cover (RAP)",
                    "group": "Land Cover",
                    "colormap": "greens",
                    "rescale": "0,60",
                    "legend_label": "% cover"
                },
                {
                    "id": "rap-iag-cog",
                    "display_name": "Invasive Annual Grass (RAP)",
                    "group": "Land Cover",
                    "colormap": "reds",
                    "rescale": "0,50",
                    "legend_label": "% cover"
                },
                {
                    "id": "wgfd-elk-seasonal-pmtiles",
                    "display_name": "Elk Crucial Range",
                    "group": "Wildlife Habitat",
                    "visible": true,
                    "default_filter": ["match", ["get", "RANGE"], ["CRUWYL", "CRUWIN", "CRUSWR"], true, false],
                    "default_style": { "fill-color": "#E65100", "fill-opacity": 0.5 },
                    "tooltip_fields": ["RANGE", "Acres"]
                },
                {
                    "id": "wgfd-mule-deer-seasonal-pmtiles",
                    "display_name": "Mule Deer Crucial Range",
                    "group": "Wildlife Habitat",
                    "visible": true,
                    "default_filter": ["match", ["get", "RANGE"], ["CRUWYL", "CRUWIN", "CRUSWR"], true, false],
                    "default_style": { "fill-color": "#2E7D32", "fill-opacity": 0.5 },
                    "tooltip_fields": ["RANGE", "Acres"]
                },
                {
                    "id": "wgfd-pronghorn-seasonal-pmtiles",
                    "display_name": "Pronghorn Crucial Range",
                    "group": "Wildlife Habitat",
                    "visible": true,
                    "default_filter": ["match", ["get", "RANGE"], ["CRUWYL", "CRUWIN", "CRUSWR"], true, false],
                    "default_style": { "fill-color": "#1565C0", "fill-opacity": 0.5 },
                    "tooltip_fields": ["RANGE", "Acres"]
                },
                {
                    "id": "sage-grouse-priority-pmtiles",
                    "display_name": "Sage-Grouse Core Areas",
                    "group": "Wildlife Habitat",
                    "default_style": { "fill-color": "#6A1B9A", "fill-opacity": 0.4 },
                    "tooltip_fields": ["NAME", "Acres"]
                },
                {
                    "id": "ungulate-migration-pmtiles",
                    "display_name": "Ungulate Migration Routes",
                    "group": "Wildlife Habitat",
                    "layer_type": "line",
                    "default_style": {
                        "line-color": ["match", ["get", "species"],
                            "Elk",               "#E65100",
                            "Mule deer",         "#2E7D32",
                            "Pronghorn",         "#1565C0",
                            "Moose",             "#6D4C41",
                            "White-tailed deer", "#558B2F",
                            "#9E9E9E"
                        ],
                        "line-opacity": 0.7
                    },
                    "tooltip_fields": ["species", "herdid", "season", "year"]
                },
                {
                    "id": "blm-sma-pmtiles",
                    "display_name": "BLM Surface Management Areas",
                    "group": "Land Management",
                    "default_filter": ["!=", ["get", "ADMIN_AGENCY_CODE"], "PVT"],
                    "default_style": {
                        "fill-color": ["match", ["get", "ADMIN_AGENCY_CODE"],
                            "BLM",  "#D4A017",
                            "USFS", "#2D7D32",
                            "NPS",  "#4E7D5A",
                            "FWS",  "#1565C0",
                            "USBR", "#6A1B9A",
                            "DOD",  "#B71C1C",
                            "ST",   "#546E7A",
                            "#9E9E9E"
                        ],
                        "fill-opacity": 0.4
                    },
                    "tooltip_fields": ["ADMIN_AGENCY_CODE", "ADMIN_UNIT_NAME", "ADMIN_UNIT_TYPE"]
                },
                {
                    "id": "wy-counties-pmtiles",
                    "display_name": "Wyoming Counties",
                    "group": "Land Management",
                    "default_style": {
                        "fill-color": "rgba(0,0,0,0)",
                        "fill-opacity": 0
                    },
                    "outline_style": {
                        "line-color": "rgba(0,0,0,0.7)",
                        "line-width": 2
                    },
                    "tooltip_fields": ["COUNTYNAME"]
                },
                {
                    "id": "wyoming-places-pmtiles",
                    "display_name": "Wyoming Incorporated Places",
                    "group": "Land Management",
                    "default_style": {
                        "fill-color": "#9C27B0",
                        "fill-opacity": 0.4
                    },
                    "tooltip_fields": ["Name", "County", "Population_2010", "County_Seat"]
                }
            ]
        },
        {
            "collection_id": "wyoming-rap-pfg-cover",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-wyoming/rap-pfg-biomass/stac-collection.json",
            "assets": [
                {
                    "id": "cog",
                    "display_name": "Perennial Forb & Grass Cover (RAP)",
                    "group": "Land Cover",
                    "colormap": "ylgn",
                    "rescale": "0,100",
                    "legend_label": "% cover"
                }
            ]
        },
        {
            "collection_id": "pad-us-4.1-combined",
            "assets": [
                {
                    "id": "pmtiles",
                    "display_name": "Protected Areas",
                    "group": "Land Ownership",
